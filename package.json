{
  "name": "@almadar/server",
  "version": "2.0.7",
  "description": "Shared server infrastructure for Almadar applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./lib": {
      "import": "./dist/lib/index.js",
      "types": "./dist/lib/index.d.ts"
    },
    "./middleware": {
      "import": "./dist/middleware/index.js",
      "types": "./dist/middleware/index.d.ts"
    },
    "./services": {
      "import": "./dist/services/index.js",
      "types": "./dist/services/index.d.ts"
    },
    "./stores": {
      "import": "./dist/stores/index.js",
      "types": "./dist/stores/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && tsc --declaration --emitDeclarationOnly --outDir dist --rootDir src --skipLibCheck || true",
    "build:watch": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run --passWithNoTests",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@almadar/agent": ">=2.0.1",
    "@almadar/core": ">=2.1.0",
    "@faker-js/faker": "^9.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "firebase-admin": "^12.0.0",
    "helmet": "^8.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "express": "^4.0.0"
  },
  "devDependencies": {
    "@almadar/eslint-plugin": ">=2.3.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/parser": "8.56.0",
    "eslint": "10.0.0",
    "express": "^4.21.0",
    "firebase-admin": "^12.0.0",
    "supertest": "^6.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/almadar-io/almadar.git",
    "directory": "docs/packages/server"
  },
  "license": "MIT",
  "keywords": [
    "almadar",
    "server",
    "express",
    "middleware"
  ],
  "homepage": "https://github.com/almadar-io/almadar#readme"
}
